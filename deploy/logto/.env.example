# Public endpoints
# Use two stable HTTPS hostnames exposed to users through your ingress path
# such as Cloudflare Tunnel. The admin console must have its own secure origin.
APP_DOMAIN=lw40.top
LOGTO_ENDPOINT=https://auth.lw40.top
LOGTO_ADMIN_ENDPOINT=https://logto.lw40.top

# Reverse proxy hostnames. Keep these aligned with the public endpoints above
# and with any Cloudflare Tunnel hostname rules in front of this stack.
AUTH_DOMAIN=auth.lw40.top
ADMIN_DOMAIN=logto.lw40.top

# PostgreSQL credentials
POSTGRES_DB=logto
POSTGRES_USER=logto
POSTGRES_PASSWORD=change-me
