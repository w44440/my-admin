# Public endpoints
# Use two stable HTTPS hostnames. The admin console must have its own secure origin.
LOGTO_ENDPOINT=https://auth.example.com
LOGTO_ADMIN_ENDPOINT=https://admin.example.com

# Reverse proxy hostnames. Keep these aligned with the public endpoints above.
AUTH_DOMAIN=auth.example.com
ADMIN_DOMAIN=admin.example.com

# PostgreSQL credentials
POSTGRES_DB=logto
POSTGRES_USER=logto
POSTGRES_PASSWORD=change-me
